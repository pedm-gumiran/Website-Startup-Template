# =====================================================
#  Consolidated .gitignore for Capstone-ConsoliGrade-System
# Covers main, frontend, and backend folders
# =====================================================

# =====================
# Logs
# =====================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =====================
# Node.js dependencies
# =====================
node_modules/
frontend/node_modules/
backend/node_modules/

# =====================
# Build output
# =====================
dist/
dist-ssr/
frontend/build/
backend/build/
backend/dist/

# =====================
# Environment variables
# =====================
.env
.env.local
frontend/.env
backend/.env

# =====================
# Local config files
# =====================
*.local
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =====================
# Editor directories
# =====================
.vscode/*
!.vscode/extensions.json
.idea/

# =====================
# OS files
# =====================
.DS_Store
Thumbs.db

# =====================
# Misc
# =====================
coverage/
*.tmp
